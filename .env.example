# -----------------------------------------------------------------------------
# VARIABLES DE ENTORNO - SUPABASE Y SERVICIOS EXTERNOS
# Renombra este archivo a ".env.local" cuando clones en tu entorno local.
# -----------------------------------------------------------------------------

# --- SUPABASE ---
# URL de tu proyecto de Supabase (ej: https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Llave anónima pública de Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Llave de rol de servicio (MANTENER EN SECRETO, SOLO PARA EL SERVIDOR)
SUPABASE_SERVICE_ROLE_KEY=

# --- GOOGLE WORKSPACE (DRIVE & SHEETS) ---
# Claves de la cuenta de servicio o cliente OAuth de Google (según la estrategia que elijas)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Si usas una Service Account (cuenta de servicio) de Google en lugar de OAuth:
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# IDs de Documentos
# ID de la hoja de cálculo de Google Sheets donde se guardará la contabilidad
GOOGLE_SHEET_ID=
# ID de la carpeta de Google Drive donde se guardarán imágenes o PDFs
GOOGLE_DRIVE_FOLDER_ID=

# --- CONFIGURACIÓN GENERAL ---
# URL de la aplicación (útil para webhooks y redirecciones)
NEXT_PUBLIC_SITE_URL=https://work-shop-livid.vercel.app

# --- MERCADO PAGO ---
# Access Token privado. Nunca lo pongas en componentes frontend.
MERCADOPAGO_ACCESS_TOKEN=
# Usa "test" para credenciales de prueba y "production" para produccion.
MERCADOPAGO_ENV=test
# Opcional cuando tengas dominio publico para recibir webhooks.
MERCADOPAGO_WEBHOOK_URL=https://work-shop-livid.vercel.app/api/mercadopago/webhook
